# Ignore local user layouts and workspace states
.user/
.restore/

# Ignore local asset and build caches
.cache/

# Ignore FMOD text log files generated during editing
fmod_editor.log
fmod.log


# Ignore Unity's FMOD editor logs
fmod_editor.log

# Ignore local FMOD cache asset generated by the Unity editor
Assets/Plugins/FMOD/Resources/FMODStudioCache.asset
Assets/Plugins/FMOD/Resources/FMODStudioCache.asset.meta

# --- OPTIONAL: Compiled Audio Banks ---
# If your sound designer builds banks locally and you do NOT want to track 
# heavy binary bank builds in Git, uncomment the line below.
# Assets/StreamingAssets/*.bank

# --- CRITICAL: Whitelist FMOD Native Binaries ---
# Some restrictive global or Unity rules block .dll, .so, or .bundle files.
# Ensure Git NEVER ignores the FMOD native runtime libraries:
!/[Aa]ssets/Plugins/FMOD/**/lib/*
!/[Aa]ssets/Gizmos/FMOD/*
!/[Aa]ssets/Editor Default Resources/FMOD/*
